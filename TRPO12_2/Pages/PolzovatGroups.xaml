<Page x:Class="TRPO12_2.Pages.PolzovatGroups"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TRPO12_2.Pages"
      mc:Ignorable="d" 
      xmlns:service="clr-namespace:TRPO12_2.Service"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PolzovatGroups">

    <Page.Resources>
        <service:GroupService x:Key="GroupService"/>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
            <Button Content="Назад" Click="back" HorizontalAlignment="Left" Margin="0,0,0,20" Width="80"/>

            <TextBlock Text="Информация о пользователе" FontSize="24" Margin="0,0,0,20"/>
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="{Binding Login}" FontSize="16"/>
                <TextBlock Text="{Binding Name}" FontSize="16"/>
                <TextBlock Text="{Binding Email}" FontSize="16"/>
            </StackPanel>
            <TextBlock Text="Дата вступления в группу" FontSize="16" Margin="0,0,0,5"/>
            <DatePicker x:Name="DatePickerJoinedAt" 
                        SelectedDate="{Binding SelectedJoinDate, Mode=TwoWay}" Margin="0,0,0,15"/>
            <CheckBox x:Name="CheckBoxModerator" 
                      Content="Быть модератором" 
                      FontSize="16" Margin="0,0,0,20"/>
            <Button Content="Записаться в группу" 
                    Click="AddToGroup_Click" 
                    Height="40"
                    Margin="0,0,0,20"/>
        </StackPanel>
        <StackPanel Grid.Column="2">
            <TextBlock Text="Группы" FontSize="20" Margin="0,0,0,10"/>

            <ListView x:Name="GroupsListView"
                      ItemsSource="{Binding Source={StaticResource GroupService}, Path=InterestGroups}"
                      SelectedItem="{Binding SelectedGroup, Mode=TwoWay}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="5">
                            <TextBlock Text="{Binding Title}" FontSize="16"/>
                            <TextBlock Text="{Binding Description}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </Grid>
</Page>