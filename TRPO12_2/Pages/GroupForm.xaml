<Page x:Class="TRPO12_2.Pages.GroupForm"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TRPO12_2.Pages"
      xmlns:validation="clr-namespace:TRPO12_2.ValidationRules"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="GroupForm">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <StackPanel>
            <StackPanel>
                <Label>Название Группы</Label>
                <TextBox x:Name="TitleTextBox">
                    <TextBox.Text>
                        <Binding Path="Title" UpdateSourceTrigger="PropertyChanged">
                            <Binding.ValidationRules>
                                <validation:GroupNameValidation />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>
            </StackPanel>
            <StackPanel>
                <Button Click="save">Сохранить</Button>
                <Button Click="back">Назад</Button>
            </StackPanel>
        </StackPanel>
        <ListView Grid.Column="1"
                  ItemsSource="{Binding UserInterestGroups}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <TextBlock>
                        <Run Text="Логин: "/>
                        <Run Text="{Binding Polzovat.Login}"/>
                        <Run Text=" / Имя: "/>
                        <Run Text="{Binding Polzovat.Name}"/>
                        <Run Text=" / Модератор: "/>
                        <Run Text="{Binding IsModerator}"/>
                    </TextBlock>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>

